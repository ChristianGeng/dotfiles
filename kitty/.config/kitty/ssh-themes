# Host -> kitty tint map, used by the ssh() wrapper in ~/.bash_aliases.
#
# Format:  <glob-pattern>   <theme-file under ~/.config/kitty/themes/>   <tab-color>
#   - theme-file: dark background tint applied to the whole window (set-colors)
#   - tab-color : bright accent for the active tab in the tab bar (set-tab-color)
# Each pattern is matched against BOTH the resolved HostName (ssh -G) and the
# target you typed. First match wins. Blank lines and #-comments are ignored.
#
# Local shell (not via ssh) intentionally has no entry -> stays the default,
# untinted theme + tab, so "untinted == I'm local".

iva-p4d-param*       host-red.conf    #ff5555
*iva-demo*           host-blue.conf   #5599ff
