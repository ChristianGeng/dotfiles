#!/bin/bash
# generate-local-configs - Generate ~/.local_configs from template and pass store
# Part of the dotfiles credential management system

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Directory containing this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"

# Paths
TEMPLATE_FILE="$DOTFILES_DIR/bash/.local_configs.template"
SPEC_FILE="$DOTFILES_DIR/bash/.local_configs.spec"
OUTPUT_FILE="$HOME/.local_configs"

# Print colored message
print_msg() {
  echo -e "${GREEN}[GENERATE]${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

# Check dependencies
check_deps() {
  if ! command -v pass &> /dev/null; then
    print_error "pass is not installed. Please install pass first."
    exit 1
  fi

  if ! command -v emacs &> /dev/null; then
    print_error "emacs is not installed. Please install emacs first."
    exit 1
  fi

  if [[ ! -f "$TEMPLATE_FILE" ]]; then
    print_error "Template file not found: $TEMPLATE_FILE"
    exit 1
  fi

  if [[ ! -f "$SPEC_FILE" ]]; then
    print_error "Spec file not found: $SPEC_FILE"
    exit 1
  fi
}

# Generate configs using Emacs Lisp
generate_configs() {
  print_msg "Generating local configs from pass store..."
  
  # Export variables for Emacs
  export TEMPLATE_FILE
  export SPEC_FILE
  export OUTPUT_FILE
  
  # Run Emacs with the Lisp file
  emacs --batch --quick --load "$SCRIPT_DIR/generate-local-configs.el"
  
  # Make output file executable
  chmod +x "$OUTPUT_FILE"
  
  print_msg "Generated $OUTPUT_FILE successfully"
}

# Show what would be generated (dry run)
dry_run() {
  print_msg "Dry run - showing what would be generated:"
  echo
  echo "Template: $TEMPLATE_FILE"
  echo "Spec: $SPEC_FILE"
  echo "Output: $OUTPUT_FILE"
  echo
  echo "Credentials that will be used:"
  
  # Parse spec and check each entry
  emacs --batch --quick --eval "
    (progn
      (find-file \"$SPEC_FILE\")
      (goto-char (point-min))
      (setq specs (read (current-buffer)))
      (dolist (spec specs)
        (let* ((name (car spec))
               (pass-path (plist-get (cdr spec) :pass))
               (env-var (plist-get (cdr spec) :env))
               (has-value (string-empty-p (string-trim (shell-command-to-string (concat \"pass show \" pass-path \" 2>/dev/null || echo ''\"))))))
          (princ (format \"  %-20s -> %-30s %s\\n\" 
                        env-var 
                        pass-path 
                        (if has-value \"[MISSING]\" \"[OK]\"))))))"
}

# Main function
main() {
  local dry_run=false
  
  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run|-n)
        dry_run=true
        shift
        ;;
      --help|-h)
        echo "Usage: $0 [OPTIONS]"
        echo
        echo "Options:"
        echo "  --dry-run, -n    Show what would be generated without doing it"
        echo "  --help, -h       Show this help message"
        echo
        exit 0
        ;;
      *)
        print_error "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  # Check dependencies
  check_deps

  # Run dry run or generate
  if $dry_run; then
    dry_run
  else
    generate_configs
    print_msg "You can now run: source ~/.local_configs"
  fi
}

# Run main function
main "$@"
